# Example environment file for local development ONLY.
# 1. Copy this to .env (or just use export in shell)
# 2. Fill in your real key
# 3. NEVER commit .env to git (it should be in .gitignore)
# 4. The extension reads process.env directly — source this file or export manually.

# For xAI (Grok) — recommended for cost-effective experiments
XAI_API_KEY=xai-YOUR_REAL_KEY_HERE

# Alternatives if you switch providers
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Ollama (for local coding agent; start with: ollama serve && ollama pull qwen2.5-coder:14b or per config)
# OLLAMA_HOST=http://127.0.0.1:11434

# Smoke / Tier flags (see meta-process/E2E_VALIDATION_RUNBOOK.md and PRODUCT_MVP_PLAN §10)
# REAL_XAI_TEST=1
# REAL_OLLAMA_TEST=1
# TIER3_SMOKE=1   # full live daily workflow (plan→delegate→continue) + P6 live report
# For P6 clean-install smoke + vsix validation use packaged .vsix + setup steps in runbook.
